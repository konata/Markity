{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markity",
  "version": "0.1.7",
  "identifier": "local.konata.markity.tauri",
  "build": {
    "frontendDist": "../dist/tauri",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev:tauri",
    "beforeBuildCommand": "bun run build:tauri"
  },
  "app": {
    "windows": [
      { "title": "Markity", "width": 1180, "height": 860, "minWidth": 760, "minHeight": 520, "theme": "Dark", "backgroundColor": "#17150f" }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "fileAssociations": [
      { "ext": ["md", "markdown", "mkd", "mdx", "mdc", "txt"], "name": "Markdown Document", "role": "Viewer" }
    ]
  }
}
